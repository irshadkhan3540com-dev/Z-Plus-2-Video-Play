<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true"> <!-- Keeps screen awake natively -->

    <!-- The Google Media3 Player View with VIP settings -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit" 
        app:use_controller="true"
        app:controller_layout_id="@layout/custom_player_controls"
        app:controller_show_timeout="2500" 
        app:show_buffering="when_playing" 
        app:surface_type="texture_view" /> 
        <!-- TextureView prevents black screen glitches on older Androids -->

</RelativeLayout>
